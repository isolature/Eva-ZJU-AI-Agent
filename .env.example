# ============================================================
# 钉钉群 AI Agent —— 配置模板
# 用法：复制本文件为 .env，把占位符换成真实值。.env 已被 .gitignore 排除，绝不提交。
# ============================================================

# ===== 钉钉应用凭证（必填）=====
# 钉钉开放平台 → 应用管理 → 你的应用 → 凭证与基础信息
DINGTALK_APP_KEY=在这里填你的AppKey
DINGTALK_APP_SECRET=在这里填你的AppSecret
# 用于“主动发送消息”（日程提醒 / 每日简报 / 公众号通知）的企业内部应用 AgentId
# 不填则：消息仍会保存，但不会主动推送
DINGTALK_AGENT_ID=在这里填你的AgentId
# 接收主动消息的钉钉用户 userid（每日简报/公众号通知推给谁）。日程提醒会自动用创建者 id。
DINGTALK_OWNER_USERID=在这里填你的钉钉userid

# ===== DeepSeek（必填）=====
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=在这里填你的DeepSeekKey

# ===== 和风天气 QWeather（天气工具）=====
# 1) https://dev.qweather.com/ 注册并实名 2) 控制台新建项目拿 API KEY 3) 设置里查专属 API Host
QWEATHER_API_KEY=在这里填你的和风APIKey
QWEATHER_API_HOST=abcxyz.qweatherapi.com

# ===== Tavily 联网搜索 =====
# https://app.tavily.com/  注册后拿 API Key（tvly- 开头），有免费额度
TAVILY_API_KEY=在这里填你的TavilyKey
TAVILY_MAX_RESULTS=5

# ===== 浙大 WebVPN（教务通知工具：校外服务器访问 zdbk 时需要）=====
# auto=自动探测(本地校园网直连/云上走WebVPN)  vpn=强制WebVPN  direct=强制直连
ZJU_WEBVPN_MODE=auto
ZJU_WEBVPN_USERNAME=你的浙大统一身份认证用户名
ZJU_WEBVPN_PASSWORD=你的浙大统一身份认证密码

# ===== 长期记忆 + 课表（SQLite）=====
MEMORY_DB_PATH=data/agent.db
# 课表 JSON 文件路径（你整理好后放这里，首次启动会导入到 SQLite）
COURSES_JSON_PATH=config/courses.json

# ===== 日程提醒（SQLite + 后台轮询）=====
REMINDER_DB_PATH=data/agent.db
REMINDER_POLL_SECONDS=30
REMINDER_MAX_RETRIES=3

# ===== 每日简报 / 自动化定时任务 =====
DAILY_BRIEFING_ENABLED=true
DAILY_BRIEFING_TIME=07:30
DAILY_BRIEFING_CITY=杭州

# ===== 微信公众号通知（消费 we-mp-rss 的 RSS/JSON 接口）=====
# 配置了 WECHAT_RSS_URL 才启用（留空则自动跳过）。部署步骤见《we-mp-rss部署教程.md》。
# 同机部署用 127.0.0.1；双服务器填另一台的内网/公网地址，例：http://你的服务器B公网IP:8001/feed/all.json
WECHAT_RSS_URL=
WECHAT_RSS_POLL_SECONDS=1800
WECHAT_RSS_LIMIT=20
